{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./dist",
    "baseUrl": "../../",
    "incremental": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@repo/backend-domain": ["packages/backend/domain/src"],
      "@repo/backend-infrastructure": ["packages/backend/infrastructure/src"],
      "@repo/backend-application": ["packages/backend/application/src"]
    }
  },
  "include": ["src/**/*", ".config/**/*", "server.ts"],
  "references": [
    { "path": "../../packages/backend/domain" },
    { "path": "../../packages/backend/infrastructure" },
    { "path": "../../packages/backend/application" }
  ]
}
